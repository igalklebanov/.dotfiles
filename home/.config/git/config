[branch]
	sort = "-committerdate"

[column]
	ui = "auto"

[commit]
	gpgSign = true

[core]
	editor = "code"
	fsmonitor = true

[fetch]
	prune = true
	writeCommitGraph = true

[filter "lfs"]
	clean = "git-lfs clean -- %f"
	process = "git-lfs filter-process"
	required = true
	smudge = "git-lfs smudge -- %f"

[gpg]
	format = "ssh"

[init]
	defaultBranch = "main"

[pull]
	rebase = true

[rebase]
	updateRefs = true

[rerere]
	enabled = true

[tag]
	gpgSign = true

[user]
	email = "igalklebanov@gmail.com"
	name = "Igal Klebanov"
	signingKey = "~/.ssh/id_ed25519_github.pub"
[credential]
	helper = osxkeychain
